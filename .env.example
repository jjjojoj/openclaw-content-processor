# Prefer reusing the local OpenClaw Z.AI / GLM provider when available.
# This lets the skill share the same coding-plan setup instead of duplicating keys.
# CONTENT_PROCESSOR_USE_OPENCLAW_ZAI=1
# CONTENT_PROCESSOR_OPENCLAW_MODEL_REF=zai/glm-4.7
# CONTENT_PROCESSOR_OPENCLAW_CONFIG=/Users/you/.openclaw/openclaw.json

# Optional OpenAI-compatible analysis
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
# CONTENT_PROCESSOR_OPENAI_RESPONSES_URL=https://api.openai.com/v1/responses
# For providers like GLM / MiniMax that do not support Responses API:
# CONTENT_PROCESSOR_OPENAI_RESPONSES_URL=https://open.bigmodel.cn/api/coding/paas/v4/chat/completions

# Optional analysis behavior
CONTENT_PROCESSOR_ANALYSIS_MODE=auto
# For GLM Coding Plan, use glm-4.7 by default. Avoid using flash models as the default.
CONTENT_PROCESSOR_ANALYSIS_MODEL=gpt-5-mini
CONTENT_PROCESSOR_ANALYSIS_TIMEOUT=60

# Optional output behavior
CONTENT_PROCESSOR_OUTPUT_MODE=auto
# Supported output targets are desktop reports and Obsidian. Feishu / Wiki upload is out of scope.
# CONTENT_PROCESSOR_OBSIDIAN_VAULT=/absolute/path/to/your/ObsidianVault
CONTENT_PROCESSOR_OBSIDIAN_FOLDER=Inbox/内容摘要
CONTENT_PROCESSOR_OBSIDIAN_LAYOUT=knowledge-card

# Optional GitHub API override
CONTENT_PROCESSOR_GITHUB_API_BASE=https://api.github.com

# Optional request/session settings
# CONTENT_PROCESSOR_COOKIES_FILE=/absolute/path/to/cookies.txt
# CONTENT_PROCESSOR_COOKIES_FROM_BROWSER=chrome
# CONTENT_PROCESSOR_COOKIE_HEADER=sessionid=abc123; other=value
# CONTENT_PROCESSOR_REFERER=https://mp.weixin.qq.com/
# CONTENT_PROCESSOR_AUTO_LOGIN_DOUYIN=1
# Only enable this on a self-hosted runner / VNC / remote desktop where a human can actually scan the QR code.
# CONTENT_PROCESSOR_ALLOW_NON_TTY_DOUYIN_LOGIN=1

# Optional binary/runtime overrides
# CONTENT_PROCESSOR_PYTHON=python3
# SCRAPLING_BIN=/absolute/path/to/scrapling
# WHISPER_MODEL=/absolute/path/to/ggml-small.bin
